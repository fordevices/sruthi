# MP3 files — excluded, but folder structure is preserved via .gitkeep
*.mp3

# Regression test fixtures are explicitly tracked
!tests/fixtures/**/*.mp3
!tests/fixtures/**/*.MP3

# Runtime database — generated on first run
music.db

# Python cache
__pycache__/
*.pyc
*.pyo

# Claude Code memory
.claude/

# Organised output (auto-created at runtime)
Music/

# Run logs (auto-created at runtime)
runs/

# Windows / iTunes folder metadata (never commit these)
Thumbs.db
desktop.ini
AlbumArt*.jpg
AlbumArtSmall.jpg
Folder.jpg
.env
